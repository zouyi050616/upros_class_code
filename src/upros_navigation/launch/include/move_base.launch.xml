<launch>
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find upros_navigation)/config/costmap/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find upros_navigation)/config/costmap/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find upros_navigation)/config/costmap/local_costmap_params.yaml" command="load"/>
    <rosparam file="$(find upros_navigation)/config/costmap/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find upros_navigation)/config/costmap/prohibition_areas.yaml" command="load" ns="global_costmap/costmap_prohibition_layer" />
    <rosparam file="$(find upros_navigation)/config/costmap/prohibition_areas.yaml" command="load" ns="local_costmap/costmap_prohibition_layer" />
    <!-- <rosparam file="$(find upros_navigation)/config/planner/dwa_local_planner_params.yaml" command="load" /> -->
    <rosparam file="$(find upros_navigation)/config/planner/teb_local_planner_params.yaml" command="load" />
    <rosparam file="$(find upros_navigation)/config/planner/global_planner_params.yaml" command="load" />
    <rosparam file="$(find upros_navigation)/config/move_base_params.yaml" command="load" />
  </node>
</launch>
