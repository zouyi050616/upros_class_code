<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="single_arm">

  <!--定义机械臂的宏-->
  <xacro:macro name="add_single_arm">

    <link name="arm_base_link">
      <inertial>
        <origin xyz="-1.7947E-07 -0.0018392 0.042093" rpy="0 0 0" />
        <mass value="0.01029" />
        <inertia ixx="0.00016721" ixy="-1.4903E-10" ixz="-3.0653E-10" iyy="0.00016551"
          iyz="-2.4534E-06" izz="0.0001699" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/arm_base_link.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/arm_base_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="arm_joint" type="fixed">
      <origin xyz="0.10 0.0 0.06" rpy="0 0 -1.57" />
      <parent link="base_link" />
      <child link="arm_base_link" />
      <axis xyz="0 0 0" />
    </joint>
    <gazebo reference="arm_base_link">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="link_1">
      <inertial>
        <origin xyz="0.00015999 -3.7029E-07 0.0067201" rpy="0 0 0" />
        <mass value="0.018148" />
        <inertia ixx="3.0609E-05" ixy="-5.9099E-11" ixz="-1.3841E-07" iyy="3.6584E-05"
          iyz="4.9301E-10" izz="2.3547E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_1.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_1.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="joint_1" type="revolute">
      <origin xyz="0 0 0.072247" rpy="0 0 0" />
      <parent link="arm_base_link" />
      <child link="link_1" />
      <axis xyz="0 0 1" />
      <limit lower="-1.8" upper="1.8" effort="50" velocity="2" />
    </joint>
    <gazebo reference="link_1">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="link_2">
      <inertial>
        <origin xyz="0.028477 -5.0821E-07 0.038913" rpy="0 0 0" />
        <mass value="0.019654" />
        <inertia ixx="1.8351E-05" ixy="-6.0792E-11" ixz="-6.4071E-08" iyy="3.1671E-05"
          iyz="3.6197E-10" izz="1.6517E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_2.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_2.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="joint_2" type="revolute">
      <origin xyz="-0.028151 0 0.034" rpy="0 0 0" />
      <parent link="link_1" />
      <child link="link_2" />
      <axis xyz="1 0 0" />
      <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>
    <gazebo reference="link_2">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="link_3">
      <inertial>
        <origin xyz="0.028363 -4.679E-07 0.054247" rpy="0 0 0" />
        <mass value="0.013931" />
        <inertia ixx="3.1912E-05" ixy="-6.0429E-11" ixz="-9.8626E-08" iyy="4.873E-05"
          iyz="4.797E-10" izz="2.0341E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_3.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_3.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="joint_3" type="revolute">
      <origin xyz="9.8516E-05 0 0.061" rpy="0 0 0" />
      <parent link="link_2" />
      <child link="link_3" />
      <axis xyz="1 0 0" />
      <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>
    <gazebo reference="link_3">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="link_4">
      <inertial>
        <origin xyz="0.028255 -0.0047504 0.06611" rpy="0 0 0" />
        <mass value="0.01537" />
        <inertia ixx="9.6221E-05" ixy="-3.6252E-10" ixz="2.7529E-08" iyy="7.3811E-05"
          iyz="7.9136E-06" izz="6.9537E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_4.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_4.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="joint_4" type="revolute">
      <origin xyz="0 0 0.081" rpy="0 0 0" />
      <parent link="link_3" />
      <child link="link_4" />
      <axis xyz="1 0 0" />
      <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>
    <gazebo reference="link_4">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="link_5">
      <inertial>
        <origin xyz="4.4212E-05 0.0041269 0.025698" rpy="0 0 0" />
        <mass value="0.018063" />
        <inertia ixx="3.7917E-05" ixy="1.4713E-07" ixz="-1.1994E-07" iyy="5.5952E-05"
          iyz="2.3438E-06" izz="5.2518E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_5.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/link_5.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="joint_5" type="revolute">
      <origin xyz="0.02825 0 0.0975" rpy="0 0 0" />
      <parent link="link_4" />
      <child link="link_5" />
      <axis xyz="0 0 -1" />
      <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>
    <gazebo reference="link_5">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="claw_link_1">
      <inertial>
        <origin xyz="0.0054256 -0.015308 0.019147" rpy="0 0 0" />
        <mass value="0.018231" />
        <inertia ixx="6.9914E-06" ixy="-3.7017E-08" ixz="1.3043E-06" iyy="6.7797E-06"
          iyz="4.9174E-08" izz="2.5386E-06" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/claw_link_1.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/claw_link_1.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="claw_joint_1" type="revolute">
      <origin xyz="-0.028 0.015 0.0462" rpy="0 0 0" />
      <parent link="link_5" />
      <child link="claw_link_1" />
      <axis xyz="0 -1 0" />
      <limit lower="-1.5" upper="1.5" effort="10" velocity="3" />
    </joint>
    <gazebo reference="claw_link_1">
      <material>Gazebo/Gray</material>
    </gazebo>

    <link name="claw_link_2">
      <inertial>
        <origin xyz="-0.0054256 -0.015308 0.019147" rpy="0 0 0" />
        <mass value="0.018231" />
        <inertia ixx="6.9914E-06" ixy="3.7016E-08" ixz="-1.3043E-06" iyy="6.7797E-06"
          iyz="4.9173E-08" izz="2.5386E-06" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/claw_link_2.STL" />
        </geometry>
        <material name="">
          <color rgba="0.2 0.2 0.2 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://upros_description/meshes/arm/claw_link_2.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="claw_joint_2" type="revolute">
      <origin xyz="0.027609 0.015 0.0462" rpy="0 0 0" />
      <parent link="link_5" />
      <child link="claw_link_2" />
      <axis xyz="0 -1 0" />
      <limit lower="-1.5" upper="1.5" effort="10" velocity="3" />
    </joint>
    <gazebo reference="claw_link_2">
      <material>Gazebo/Gray</material>
    </gazebo>

    <!-- ros_control plugin -->
    <gazebo>
      <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
        <robotNamespace>/</robotNamespace>
        <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
        <legacyModeNS>true</legacyModeNS>
      </plugin>
    </gazebo>

  </xacro:macro>

  <!-- Transmissions for ROS Control -->
  <xacro:macro name="transmission_block" params="joint_name">
    <transmission name="tran1">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${joint_name}">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor1">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
  </xacro:macro>

</robot>