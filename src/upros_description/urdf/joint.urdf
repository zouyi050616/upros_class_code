<?xml version="1.0"?>
<robot name="two_cylinder_robot">

    <!--定义第一个连杆-->
    <link name="link1">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.2" />
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.2" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0" />
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
        </inertial>
    </link>
    <gazebo reference="link1">
        <material>Gazebo/Black</material>
    </gazebo>

    <!--定义第二个连杆-->
    <link name="link2">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.2" />
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.2" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0" />
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
        </inertial>
    </link>

    <!--定义旋转关节-->
    <joint name="joint1" type="revolute">
        <parent link="link1" />
        <child link="link2" />
        <axis xyz="0 0 1" />
        <origin xyz="0 0 0.2" rpy="0 0 0" />
        <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0" />
    </joint>

</robot>