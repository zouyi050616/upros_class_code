<launch>
    <!-- 1 四轮全向底盘  2 三轮全向底盘  3 双轮差速底盘 -->
    <arg name="chassis_type" default="3"/>

    <!-- 机器人通信节点 -->
    <node name="zoo_driver" pkg="zoo_bringup" type="zoo_driver" output="screen">
        <rosparam file="$(find zoo_bringup)/params/base_params_with_imu_w2a.yaml" command="load"/>
        <param name="chassis_type" type="int" value="$(arg chassis_type)"/>
    </node>

    <!-- 机器人模型加载 -->
    <param name="robot_description" command="$(find xacro)/xacro -i '$(find zoo_description)/urdf/w2a.urdf'"/>

    <!-- 发布关节角度 -->
    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher">
        <param name="rate" value="40.0"/>
    </node>

    <!-- 依据模型发布TF变换 -->
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
        <param name="rate" value="40.0"/>
    </node>

</launch>
