<launch>

  <param name="use_sim_time" value="false" />

  <arg name="map_name" default="my_lab.yaml" />

  <node pkg="upros_lidar_filter" type="blob_lidar_filter" name="blob_lidar_filter" output="screen"/>

  <node name="map_server" pkg="map_server" type="map_server" args="$(find upros_navigation)/maps/$(arg map_name)"/>

  <include file="$(find w2u_navigation)/launch/include/amcl.launch.xml" />

  <include file="$(find w2u_navigation)/launch/include/move_base.launch.xml" />

  <!-- AMCL publishes map -> odom_combined during navigation. Do not run ICP localization at the same time. -->
  <!-- <node name="pcl_laser_icp" pkg="upros_lidar_filter" type="pcl_laser_icp" output="screen"/> -->

</launch>
